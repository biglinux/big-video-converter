# File: big-video-converter/big-video-converter/usr/share/big-video-converter/main.py, line: 482
msgid "Audio"
msgstr "Ljud"
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/audio_dialog.py, line: 122
msgid ""
"Configure how the audio track will be handled. Copying keeps the original quality. Re-encoding "
"allows changes."
msgstr ""
"Konfigurera hur ljudspåret ska hanteras. Kopiering behåller den ursprungliga kvaliteten. Omskodning "
"möjliggör ändringar."
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/audio_dialog.py, line: 139
msgid "Audio Handling"
msgstr "Ljudhantering"
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/audio_dialog.py, line: 141
msgid ""
"Choose what to do with the audio track. 'Copy' keeps the original. 'Re-encode' allows changing "
"codec, bitrate and applying audio cleaning."
msgstr ""
"Välj vad du vill göra med ljudspåret. 'Kopiera' behåller originalet. 'Omkoda' möjliggör ändring av "
"codec, bitrate och tillämpning av ljudrensning."
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/audio_dialog.py, line: 156
msgid "Audio Codec"
msgstr "Ljudcodec"
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/audio_dialog.py, line: 158
msgid ""
"The format used to compress audio. AAC is widely compatible. Opus offers better quality at lower "
"bitrates. Choose 'Copy' in audio handling to keep the original codec."
msgstr ""
"Formatet som används för att komprimera ljud. AAC är allmänt kompatibelt. Opus erbjuder bättre "
"kvalitet vid lägre bithastigheter. Välj 'Kopiera' i ljudhantering för att behålla den ursprungliga "
"codec."
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/audio_dialog.py, line: 173
msgid "Audio Bitrate"
msgstr "Ljudbitrate"
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/audio_dialog.py, line: 175
msgid "Higher bitrate means better audio quality but larger files. 192k is a good balance for most content."
msgstr ""
"Högre bithastighet innebär bättre ljudkvalitet men större filer. 192k är en bra balans för det "
"mesta innehållet."
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/settings_page.py, line: 221
msgid "Custom bitrate"
msgstr "Anpassad bithastighet"
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/audio_dialog.py, line: 228
msgid "Audio Channels"
msgstr "Ljudkanaler"
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/audio_dialog.py, line: 230
msgid ""
"'Default' keeps the original channel count from the source video. Stereo (2) is standard. Mono (1) "
"for voice only. 5.1 (6) for surround sound."
msgstr ""
"'Standard' behåller det ursprungliga kanalantalet från källvideon. Stereo (2) är standard. Mono (1) "
"för endast röst. 5.1 (6) för surroundljud."
