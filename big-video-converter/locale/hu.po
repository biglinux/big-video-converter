# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/constants.py, line: 276
msgid ""
"Select parts of the video to keep.\n"
"\n"
"Add sections with the + button or directly in the video using the markers button above the video.\n"
"\n"
"You can export selected parts as one file or as multiple clips\n"
" ideal for creating short videos for social media."
msgstr ""
"Válassza ki a megtartandó videórészeket.\n"
"\n"
"Adjon hozzá szakaszokat a + gombbal vagy közvetlenül a videóban a videó felett található jelölőgomb "
"segítségével.\n"
"\n"
"A kiválasztott részeket egy fájlként vagy több klipként exportálhatja, ami ideális a közösségi "
"média számára készült rövid videók készítéséhez."
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/constants.py, line: 282
msgid ""
"Run decode on the CPU and encode on the GPU.\n"
"\n"
"Usually best left disabled, but can help with certain compatibility issues."
msgstr ""
"Futtassa a dekódolást a CPU-n és a kódolást a GPU-n.\n"
"\n"
"Általában a legjobb, ha le van tiltva, de segíthet bizonyos kompatibilitási problémák esetén."
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/constants.py, line: 286
msgid ""
"Audio quality:\n"
"\n"
"• Higher = better quality, larger file\n"
"• 128k: Good for most content\n"
"• 192k: High quality\n"
"• 256k+: Professional use\n"
"• Default: Auto (encoder decides)"
msgstr ""
