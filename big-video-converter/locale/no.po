msgid ""
"Number of audio channels:\n"
"\n"
"• 1: Mono (single speaker)\n"
"• 2: Stereo (left/right)\n"
"• 6: 5.1 Surround\n"
"• 8: 7.1 Surround\n"
"• Default: Keep original"
msgstr ""
