msgid "GPU partial mode"
msgstr "Частичен режим на GPU"
# 
# File: big-video-converter/big-video-converter/usr/share/big-video-converter/ui/settings_page.py, line: 118
msgid "Decode using CPU, encode using GPU"
msgstr "Декодиране с CPU, кодиране с GPU"
